# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's in .gitignore for a reason.

# Public — exposed to the browser. Safe.
NEXT_PUBLIC_SUPABASE_URL=https://dhotmtgryuovkmsncdby.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace-me...

# Server-only — never expose to the browser. Used for upserts in /api/upload
# and /api/ingest. In Vercel you can alternatively name these SUPABASE_URL /
# SUPABASE_SERVICE_KEY; the admin client accepts either naming.
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace-me...

# Shared secret that the browser extension sends in
# `Authorization: Bearer <key>` when POSTing to /api/ingest.
# Pick any long random string; rotate by changing it here and in the extension.
INGEST_API_KEY=geck-2026-secret

# -- Geck Data pipeline (scrapers + /data-admin) -------------------------

# Same as SUPABASE_SERVICE_ROLE_KEY above; the Python scripts accept either
# name. Set this if you prefer the shorter SUPABASE_SERVICE_KEY everywhere.
# SUPABASE_SERVICE_KEY=eyJ...replace-me...

# Decodo Web Scraping API basic auth, e.g. "Basic dXNlcjpwYXNz". Paste it
# whole, including the literal "Basic " prefix. Used by scrape_listings.py
# and scrape_details.py.
DECODO_AUTH=

# Your Supabase Auth user id. Find it in Supabase dashboard > Authentication
# > Users after you sign up at /login. /data-admin/* is gated to this id.
ADMIN_USER_ID=

# Fine-grained Personal Access Token with "Actions: read and write" scope on
# the geck-data repo. Used by /api/trigger-scrape to dispatch GitHub Actions.
# Generate at: GitHub > Settings > Developer settings > Personal access tokens.
GITHUB_PAT=

# Owner/repo string. Should match the repo this code is deployed from.
GITHUB_REPO=tennysonmilesperhour/geck-data
