# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's in .gitignore for a reason.

# Public — exposed to the browser. Safe.
NEXT_PUBLIC_SUPABASE_URL=https://dhotmtgryuovkmsncdby.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace-me...

# Server-only — never expose to the browser. Used for upserts in /api/upload
# and /api/ingest. In Vercel you can alternatively name these SUPABASE_URL /
# SUPABASE_SERVICE_KEY; the admin client accepts either naming.
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace-me...

# Shared secret that the browser extension sends in
# `Authorization: Bearer <key>` when POSTing to /api/ingest.
# Pick any long random string; rotate by changing it here and in the extension.
INGEST_API_KEY=geck-2026-secret
